    <string name="onb_imap_password_placeholder">App-specific password</string>
    <string name="onb_imap_cta">Save</string>

    <!-- Onboarding: Google Calendar -->
    <string name="onb_gcal_title">Google Calendar</string>
    <string name="onb_gcal_headline">Connect Google Calendar</string>
    <string name="onb_gcal_body">BeCalm reads your Google Calendar to surface upcoming meetings and related commitments. Read-only access. Event titles and attendees are synced; descriptions are not.</string>

    <!-- Onboarding: Outlook Calendar -->
    <string name="onb_outlook_cal_title">Outlook Calendar</string>
    <string name="onb_outlook_cal_headline">Connect Outlook Calendar</string>
    <string name="onb_outlook_cal_body">BeCalm reads your Outlook Calendar to surface upcoming meetings. Read-only access. Event titles and attendees are synced; descriptions are not.</string>

    <!-- Onboarding: Battery optimization -->
    <string name="onb_battery_title">Background Activity</string>
    <string name="onb_battery_headline">Keep BeCalm active</string>
    <string name="onb_battery_body">To capture commitments reliably, BeCalm needs to run in the background. Please disable battery optimization for BeCalm. On Samsung devices, also remove it from the Sleeping Apps list.</string>
    <string name="onb_battery_cta">Disable Battery Optimization</string>
    <string name="onb_battery_samsung_guide">Samsung: Settings → Device Care → Battery → Background usage limits → Sleeping apps → remove BeCalm</string>

