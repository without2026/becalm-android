    <string name="onb_imap_cta">저장</string>

    <!-- Onboarding: Google Calendar -->
    <string name="onb_gcal_title">Google 캘린더</string>
    <string name="onb_gcal_headline">Google 캘린더 연결</string>
    <string name="onb_gcal_body">비캄은 예정 회의 및 관련 약속을 표시하기 위해 Google 캘린더를 읽습니다. 읽기 전용 접근. 일정 제목과 참석자가 동기화되며 설명은 동기화되지 않습니다.</string>

    <!-- Onboarding: Outlook Calendar -->
