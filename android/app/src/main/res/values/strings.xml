    <!-- Onboarding: PIPA 제3자 제공 + 국외 이전 동의 (ONB-PIPA) -->
    <string name="onb_pipa_title">개인정보 제3자 제공 동의</string>
    <string name="onb_pipa_headline">음성 자동 처리를 위한 정보 제공 동의</string>
    <string name="onb_pipa_body">BeCalm은 음성 녹음 파일을 자동으로 분석하여 약속과 할 일을 추출합니다. 이를 위해 아래 내용에 따라 귀하의 녹음 파일을 Google LLC에 제공합니다. 동의를 거부하셔도 이메일·캘린더·수동 입력 기능은 정상 사용하실 수 있습니다.</string>
    <!-- Bullet 1: 제공받는 자 -->
    <string name="onb_pipa_bullet_1_label">제공받는 자</string>
    <string name="onb_pipa_bullet_1_value">Google LLC</string>
    <!-- Bullet 2: 제공 항목 -->
    <string name="onb_pipa_bullet_2_label">제공 항목</string>
    <string name="onb_pipa_bullet_2_value">녹음 파일 전체 오디오 바이트</string>
    <!-- Bullet 3: 제공 목적 -->
    <string name="onb_pipa_bullet_3_label">제공 목적</string>
    <string name="onb_pipa_bullet_3_value">약속/할 일 자동 추출 (Gemini 2.5 Flash audio multimodal)</string>
    <!-- Bullet 4: 데이터 처리 리전 -->
    <string name="onb_pipa_bullet_4_label">데이터 처리 리전</string>
    <string name="onb_pipa_bullet_4_value">us-central1 (미국 중부)</string>
    <!-- Bullet 5: 보유 및 이용 기간 -->
    <string name="onb_pipa_bullet_5_label">보유 및 이용 기간</string>
    <string name="onb_pipa_bullet_5_value">요청 처리 후 즉시 삭제 (ZDR — Zero Data Retention)</string>
    <!-- Bullet 6: 거부 권리 및 불이익 -->
    <string name="onb_pipa_bullet_6_label">거부 권리 및 불이익</string>
    <string name="onb_pipa_bullet_6_value">동의 거부 시 음성 자동 처리 기능만 비활성화되며, 나머지 앱 기능(이메일·캘린더 연동, 수동 입력)은 정상 사용 가능합니다. 설정에서 언제든지 변경하실 수 있습니다.</string>
