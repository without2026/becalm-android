    <string name="terms_subtitle">Please read and accept before continuing.</string>
    <string name="terms_pipa_notice">BeCalm collects and processes personal information (contacts, calendar events, emails) on-device under your consent as required by the Personal Information Protection Act (PIPA). Your data is stored locally first and only shared with our servers with your explicit consent.</string>
