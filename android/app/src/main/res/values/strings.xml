    <!-- Onboarding: recording folder -->
    <string name="onb_recording_folder_title">Recording Folder</string>
    <string name="onb_recording_folder_headline">Allow access to recordings</string>
    <string name="onb_recording_folder_body">BeCalm reads your voice recording files to extract commitments. Files are processed locally; only extracted commitment text is ever sent to our servers.</string>

    <!-- Onboarding: contacts -->
    <string name="onb_contacts_title">Contacts Access</string>
    <string name="onb_contacts_headline">Connect your contacts</string>
    <string name="onb_contacts_body">BeCalm reads your contact names to display people you interact with. Contact data never leaves your device. This permission can be revoked at any time.</string>
    <string name="onb_contacts_pipa">수집 목적: 상호작용 상대방 이름 표시. 보유 기간: 앱 사용 기간. 파기: 앱 삭제 또는 데이터 초기화 시.</string>

    <!-- Onboarding: Gmail OAuth -->
    <string name="onb_gmail_title">Gmail</string>
    <string name="onb_gmail_headline">Connect Gmail</string>
    <string name="onb_gmail_body">BeCalm accesses your Gmail to detect commitments in email threads. We request read-only access. Only commitment-relevant metadata is synced — full email bodies are never uploaded.</string>

    <!-- Onboarding: Outlook Mail OAuth -->
    <string name="onb_outlook_mail_title">Outlook Mail</string>
    <string name="onb_outlook_mail_headline">Connect Outlook Mail</string>
    <string name="onb_outlook_mail_body">BeCalm accesses your Outlook inbox to detect commitments in email threads. We request read-only access. Full email bodies are never uploaded.</string>

