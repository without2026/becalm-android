    <!-- Onboarding: recording folder -->
    <string name="onb_recording_folder_title">녹음 폴더</string>
    <string name="onb_recording_folder_headline">녹음 파일 접근 허용</string>
    <string name="onb_recording_folder_body">비캄은 약속 추출을 위해 음성 녹음 파일을 읽습니다. 파일은 기기에서만 처리되며, 추출된 약속 텍스트만 서버로 전송됩니다.</string>

    <!-- Onboarding: contacts -->
    <string name="onb_contacts_title">연락처 접근</string>
    <string name="onb_contacts_headline">연락처 연결</string>
    <string name="onb_contacts_body">비캄은 상호작용 상대방의 이름 표시를 위해 연락처를 읽습니다. 연락처 데이터는 기기 밖으로 전송되지 않습니다. 언제든지 권한을 취소할 수 있습니다.</string>
    <string name="onb_contacts_pipa">수집 목적: 상호작용 상대방 이름 표시. 보유 기간: 앱 사용 기간. 파기: 앱 삭제 또는 데이터 초기화 시.</string>

    <!-- Onboarding: Gmail OAuth -->
    <string name="onb_gmail_title">Gmail</string>
    <string name="onb_gmail_headline">Gmail 연결</string>
    <string name="onb_gmail_body">비캄은 이메일 스레드에서 약속을 감지하기 위해 Gmail에 접근합니다. 읽기 전용 권한을 요청합니다. 약속 관련 메타데이터만 동기화되며 이메일 본문은 업로드되지 않습니다.</string>

    <!-- Onboarding: Outlook Mail OAuth -->
    <string name="onb_outlook_mail_title">Outlook 메일</string>
    <string name="onb_outlook_mail_headline">Outlook 메일 연결</string>
    <string name="onb_outlook_mail_body">비캄은 이메일 스레드에서 약속을 감지하기 위해 Outlook 받은편지함에 접근합니다. 읽기 전용 권한을 요청합니다. 이메일 본문은 업로드되지 않습니다.</string>

    <!-- Onboarding: IMAP -->
    <string name="onb_imap_title">IMAP / 앱 비밀번호</string>
    <string name="onb_imap_headline">IMAP으로 연결</string>
    <string name="onb_imap_body">IMAP 서버 정보를 입력해 이메일 약속을 동기화하세요. 주 계정 비밀번호가 아닌 앱 전용 비밀번호를 사용하세요. 자격 증명은 기기에만 암호화 저장될 예정입니다 (출시 예정).</string>
    <string name="onb_imap_host_label">IMAP 서버</string>
    <string name="onb_imap_host_placeholder">imap.example.com</string>
    <string name="onb_imap_email_label">이메일 주소</string>
